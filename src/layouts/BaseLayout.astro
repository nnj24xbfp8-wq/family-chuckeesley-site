---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const fullTitle = title === 'Eesley · Wildermuth' ? title : `${title} — Eesley · Wildermuth`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="min-h-screen">
    <header class="border-b border-rule">
      <div class="max-w-3xl mx-auto px-6 py-5 flex items-baseline justify-between">
        <a href="/" class="no-underline">
          <span class="font-serif text-xl tracking-wide">Eesley · Wildermuth</span>
        </a>
        <nav class="text-sm space-x-5">
          <a href="/family/">Family</a>
          <a href="/docs/">Stories</a>
          <a href="/places/">Places</a>
          <a href="/archive/">Archive</a>
          <a href="/zh/" lang="zh">中文</a>
        </nav>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-10">
      <slot />
    </main>

    <footer class="border-t border-rule mt-16">
      <div class="max-w-3xl mx-auto px-6 py-6 text-sm text-ink/60">
        A family archive, kept by Chuck Eesley. Building on the work of Mary Eesley Bean,
        Margaret "Maggie" Eesley, and Robert Earl Wildermuth.
      </div>
    </footer>
  </body>
</html>
