---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate, sortableDateKey } from '../../utils/lifespan';

const arts = (await getCollection('artifacts')).sort((a, b) => {
  const ka = sortableDateKey(a.data.sortDate, a.data.dateCreated);
  const kb = sortableDateKey(b.data.sortDate, b.data.dateCreated);
  if (ka !== kb) return ka - kb;
  return a.data.title.localeCompare(b.data.title);
});
---
<BaseLayout title="Archive">
  <h1 class="text-3xl font-serif mb-2">Photo &amp; letter archive</h1>
  <p class="text-ink/70 italic mb-8">
    Catalogued objects — earliest first. Undated items at the end.
  </p>

  <ul class="grid grid-cols-2 gap-6">
    {arts.map((a) => (
      <li>
        <a href={`/archive/${a.id}/`} class="block no-underline">
          <div class="aspect-square bg-rule/40 mb-2"></div>
          <div class="font-serif">{a.data.title}</div>
          <div class="text-xs text-ink/60">
            {a.data.dateCreated ? formatDate(a.data.dateCreated) : 'Undated'}
          </div>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
