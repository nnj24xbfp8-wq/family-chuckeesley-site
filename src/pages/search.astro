---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Search" description="Search the family archive">
  <article class="prose prose-stone max-w-none">
    <h1 class="font-serif">Search</h1>
    <p class="text-ink/70">
      Full-text search across all pages of this archive &mdash; people, places, letters, memoirs,
      photographs, documents. Indexed at build time; no data leaves your browser.
    </p>

    <div id="search" class="not-prose my-8"></div>

    <p class="text-sm text-ink/60 italic">
      Powered by <a href="https://pagefind.app/">Pagefind</a> &mdash; a static-site full-text
      search engine. Try searching for a person's name (e.g. "Robert Earl"), a place
      ("Camp Eagle", "Highland Ridge"), a year ("1944"), or a concept ("malaria", "Way line").
    </p>
  </article>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        resetStyles: false,
      });
    });
  </script>
</BaseLayout>
