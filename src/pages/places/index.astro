---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const places = await getCollection('places');

// Group by country. Hand-ordered to follow the two-family narrative:
// English origins → German origins → Chinese origins → American settlement → Vietnam.
const countryOrder = ['England', 'Germany', 'China', 'United States', 'Vietnam'];

const groups = new Map<string, typeof places>();
for (const p of places) {
  const c = p.data.country ?? 'Unspecified';
  if (!groups.has(c)) groups.set(c, []);
  groups.get(c)!.push(p);
}

// Sort group keys: known countries first in the curated order, the rest alphabetically.
const sortedCountries = [...groups.keys()].sort((a, b) => {
  const ia = countryOrder.indexOf(a);
  const ib = countryOrder.indexOf(b);
  if (ia >= 0 && ib >= 0) return ia - ib;
  if (ia >= 0) return -1;
  if (ib >= 0) return 1;
  return a.localeCompare(b);
});

// Within a country: photographed first, then described-only, then unreached; ties by title.
const statusOrder = { photographed: 0, 'described-only': 1, unreached: 2 } as const;
for (const list of groups.values()) {
  list.sort((a, b) => {
    const da = statusOrder[a.data.status];
    const db = statusOrder[b.data.status];
    if (da !== db) return da - db;
    return a.data.title.localeCompare(b.data.title);
  });
}

const statusLabel: Record<string, string> = {
  photographed: 'Photographed',
  'described-only': 'Described only',
  unreached: 'Unreached',
};
---
<BaseLayout title="Places" description="The places this family touched — England, Germany, China, the United States, Vietnam.">
  <h1 class="text-3xl font-serif mb-2">Places</h1>
  <p class="text-ink/70 italic mb-2">
    Grouped by country and ordered along the two families' arrival into America —
    English origins, German origins, Chinese origins, American settlement, the war.
  </p>
  <p class="text-ink/60 text-sm mb-10">
    Status: <em>photographed</em> = at least one visit with images;
    <em>described only</em> = visited but no surviving photographs;
    <em>unreached</em> = no one in the family has been yet.
  </p>

  {sortedCountries.map((country) => (
    <section class="mb-10">
      <h2 class="text-xl font-serif mb-4 border-b border-rule pb-1">{country}</h2>
      <ul class="space-y-6">
        {groups.get(country)!.map((place) => (
          <li class="border-l-2 border-rule pl-4">
            <a href={`/places/${place.id}/`} class="text-xl font-serif">{place.data.title}</a>
            <div class="text-xs uppercase tracking-wider text-ink/50 mt-1">
              {[place.data.village, place.data.region].filter(Boolean).join(' · ')}
              {(place.data.village || place.data.region) && ' · '}
              <span class:list={["italic", place.data.status === 'unreached' && 'text-sepia']}>
                {statusLabel[place.data.status]}
              </span>
            </div>
            <p class="text-ink/80 mt-2">{place.data.summary}</p>
            {place.data.visits.length > 0 && (
              <div class="text-xs text-ink/60 mt-2">
                Visits: {place.data.visits.map((v) => v.year).join(', ')}
              </div>
            )}
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
