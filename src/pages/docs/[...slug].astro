---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resolvePeople } from '../../lib/relations';

export async function getStaticPaths() {
  const docs = await getCollection('documents');
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const author = doc.data.author
  ? (await resolvePeople([doc.data.author]))[0]
  : undefined;
const recipient = doc.data.recipient
  ? (await resolvePeople([doc.data.recipient]))[0]
  : undefined;
const people = await resolvePeople(doc.data.people);
const { Content } = await render(doc);
const isPrivate = doc.data.private === true;

// partOf — if this doc anchors to a parent collection, resolve the parent for a backlink.
const allDocs = await getCollection('documents');
const parent = doc.data.partOf
  ? allDocs.find((d) => d.id === doc.data.partOf.id)
  : undefined;

// Child letters — if this doc IS a letter-collection, gather every doc with partOf == this.id.
// Sorted by postmarkDate (falling back to dateRange.start) ascending.
const isCollection = doc.data.type === 'letter-collection';
const childLetters = isCollection
  ? allDocs
      .filter((d) => d.data.partOf?.id === doc.id)
      .sort((a, b) => {
        const da = a.data.postmarkDate ?? a.data.dateRange?.start ?? '';
        const db = b.data.postmarkDate ?? b.data.dateRange?.start ?? '';
        return da.localeCompare(db);
      })
  : [];

// Resolve recipient names for the child-letter listing.
const allPeople = isCollection ? await getCollection('people') : [];
const personById = new Map(allPeople.map((p) => [p.id, p]));
---
<BaseLayout title={doc.data.title} description={doc.data.summary}>
  <article>
    <header class="mb-8 pb-4 border-b border-rule">
      {parent && (
        <p class="text-xs mb-1">
          <a href={`/docs/${parent.id}/`} class="text-ink/60 hover:text-ink">
            &larr; Part of <em>{parent.data.title}</em>
          </a>
        </p>
      )}
      <p class="uppercase tracking-wider text-ink/50 text-xs">{doc.data.type}</p>
      <h1 class="text-4xl font-serif mt-1 mb-2">{doc.data.title}</h1>
      <p class="text-ink/70 italic">{doc.data.summary}</p>
      <div class="text-sm text-ink/60 mt-3 space-y-0.5">
        <div>
          {author && <>by <a href={`/family/${author.id}/`}>{author.data.name}</a></>}
          {recipient && <> &middot; to <a href={`/family/${recipient.id}/`}>{recipient.data.name}</a></>}
          {doc.data.postmarkDate && <> &middot; postmarked {doc.data.postmarkDate}</>}
          {!doc.data.postmarkDate && doc.data.dateRange?.start && <> &middot; {doc.data.dateRange.start}{doc.data.dateRange.end ? `–${doc.data.dateRange.end}` : ''}</>}
        </div>
        {(doc.data.locationFrom || doc.data.locationTo) && (
          <div class="text-ink/50">
            {doc.data.locationFrom && <>from {doc.data.locationFrom}</>}
            {doc.data.locationFrom && doc.data.locationTo && <> &rarr; </>}
            {doc.data.locationTo && <>to {doc.data.locationTo}</>}
          </div>
        )}
      </div>
    </header>

    {isPrivate ? (
      <div class="mb-8 border border-sepia/40 bg-sepia/5 p-5 not-prose">
        <p class="uppercase tracking-wider text-sepia text-xs mb-1">Withheld at the family's request</p>
        <p class="text-ink/80 text-sm">
          The body of this letter is held in the private family archive and is not published here.
          The metadata above &mdash; sender, recipient, date, and place &mdash; is published so the
          archive's index remains complete. To inquire about the full text, contact the family
          directly.
        </p>
      </div>
    ) : (
      <div class="prose prose-stone max-w-prose">
        <Content />
      </div>
    )}

    {!isPrivate && doc.data.scans.length > 0 && (
      <section class="mt-12 pt-6 border-t border-rule">
        <h2 class="text-xl font-serif mb-4">Scans</h2>
        <div class="space-y-6">
          {doc.data.scans.map((img, i) => (
            <figure>
              <Image src={img} alt={`${doc.data.title} — scan ${i + 1}`} class="w-full max-w-2xl" />
            </figure>
          ))}
        </div>
      </section>
    )}

    {isCollection && (
      <section class="mt-12 pt-6 border-t border-rule">
        <h2 class="text-xl font-serif mb-3">The letters</h2>
        {childLetters.length === 0 ? (
          <p class="text-sm text-ink/60 italic">
            No letters in this collection have been catalogued yet. As individual letter pages are
            added, they will appear here automatically, sorted by postmark date.
          </p>
        ) : (
          <ul class="text-sm space-y-2 not-prose">
            {childLetters.map((d) => {
              const date = d.data.postmarkDate ?? d.data.dateRange?.start ?? '';
              const isPrivateChild = d.data.private === true;
              const recip = d.data.recipient ? personById.get(d.data.recipient.id) : undefined;
              return (
                <li class="flex flex-wrap items-baseline gap-x-2">
                  <span class="uppercase tracking-wider text-xs text-ink/60 inline-block min-w-[6.5rem] font-mono">
                    {date || '—'}
                  </span>
                  <a href={`/docs/${d.id}/`} class="font-medium">{d.data.title}</a>
                  {recip && (
                    <span class="text-ink/50 text-xs">
                      to <a href={`/family/${recip.id}/`} class="hover:text-ink">{recip.data.name}</a>
                    </span>
                  )}
                  {isPrivateChild && (
                    <span class="text-sepia/80 uppercase tracking-wider text-xs">[withheld]</span>
                  )}
                </li>
              );
            })}
          </ul>
        )}
      </section>
    )}

    {people.length > 0 && (
      <section class="mt-12 pt-6 border-t border-rule">
        <h2 class="text-xl font-serif mb-3">People in this document</h2>
        <ul class="text-sm space-y-1">
          {people.map((p) => <li><a href={`/family/${p.id}/`}>{p.data.name}</a></li>)}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
