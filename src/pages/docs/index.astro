---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate, sortableDateKey } from '../../utils/lifespan';

const docs = (await getCollection('documents')).sort((a, b) => {
  const ka = sortableDateKey(a.data.sortDate, a.data.dateRange?.start);
  const kb = sortableDateKey(b.data.sortDate, b.data.dateRange?.start);
  if (ka !== kb) return ka - kb;
  return a.data.title.localeCompare(b.data.title);
});
---
<BaseLayout title="Stories &amp; memoirs">
  <h1 class="text-3xl font-serif mb-2">Stories &amp; memoirs</h1>
  <p class="text-ink/70 italic mb-8">
    Long-form narrative: memoirs, the combat log, the register, travelogues,
    ancestor sketches, letters. Sorted oldest first; undated items at the end.
  </p>
  <ul class="space-y-6">
    {docs.map((doc) => {
      const start = doc.data.dateRange?.start;
      const end = doc.data.dateRange?.end;
      const dateLine = start
        ? (end ? `${formatDate(start)} – ${formatDate(end)}` : formatDate(start))
        : '';
      // Prefer one-line `teaser` on the index; fall back to `summary` if unset.
      const blurb = doc.data.teaser ?? doc.data.summary;
      return (
        <li>
          <a href={`/docs/${doc.id}/`} class="text-xl font-serif">{doc.data.title}</a>
          <div class="text-sm text-ink/60 mt-1">
            {doc.data.type}
            {dateLine && <> &middot; {dateLine}</>}
          </div>
          <p class="text-ink/80 mt-1">{blurb}</p>
        </li>
      );
    })}
  </ul>
</BaseLayout>
